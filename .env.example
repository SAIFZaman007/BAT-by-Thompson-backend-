# Copy to .env and fill in. NEVER commit .env.
DATABASE_URL=postgresql+psycopg://bat:change-me-in-prod@localhost:5432/bahamas_ai_trading
SECRET_KEY=generate-with: python -c "import secrets;print(secrets.token_urlsafe(48))"
FERNET_KEY=generate-with: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
CORS_ORIGINS=["https://bahamasaitrading.com","https://admin.bahamasaitrading.com"]
UPLOAD_DIR=/data/uploads
SUPPORT_EMAIL=support@bahamasaitrading.com
ENVIRONMENT=production
ACCESS_TOKEN_EXPIRE_MINUTES=60
